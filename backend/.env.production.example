# ─────────────────────────────────────────────────────────────────────────────
# ACAE / Aprova — Variables de entorno de PRODUCCIÓN (backend)
# Plantilla para configurar en Dongee Node.js App Manager.
# NO commitear el archivo .env real con valores reales — solo este ejemplo.
# ─────────────────────────────────────────────────────────────────────────────

# Base de datos PostgreSQL de producción (host/credenciales del servidor Dongee)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/acae_db?schema=public"

# JWT — generar un secreto nuevo y único para producción, NUNCA reutilizar el de desarrollo.
# Generar con: openssl rand -base64 64
JWT_SECRET="REEMPLAZAR_CON_SECRETO_GENERADO_OPENSSL"
JWT_EXPIRES_IN="7d"

PORT=3001
NODE_ENV="production"

# Dominios reales de producción (sin localhost)
APP_URL="https://api.acae.com.co"
FRONTEND_URL="https://acae.com.co"

UPLOAD_DEST="./uploads"
MAX_FILE_SIZE=10485760

# ─── Email — Resend SMTP (dominio acae.com.co ya verificado en Resend) ───────
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="resend"
SMTP_PASS="REEMPLAZAR_CON_API_KEY_DE_RESEND"
SMTP_FROM="noreply@acae.com.co"

# Debe quedar en false en producción — deshabilita GET /api/email/test
ENABLE_EMAIL_TEST="false"
