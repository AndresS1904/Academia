DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/acae_db?schema=public"

JWT_SECRET="replace-with-a-random-256-bit-secret"
JWT_EXPIRES_IN="7d"

PORT=3001
NODE_ENV="development"
APP_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

UPLOAD_DEST="./uploads"
MAX_FILE_SIZE=10485760

# ─── Email — Resend SMTP ─────────────────────────────────────────────────────
# Docs: https://resend.com/docs/send-with-smtp
#
# Desarrollo: usa onboarding@resend.dev como SMTP_FROM (solo entrega a correos
# verificados en tu cuenta de Resend). Para ver el enlace de reset sin SMTP
# real, deja estas vars vacías y el servidor lo imprimirá en los logs.
#
# Producción: verifica el dominio acae.com.co en resend.com/domains, luego
# cambia SMTP_FROM a "noreply@acae.com.co".
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="resend"
SMTP_PASS="re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
SMTP_FROM="onboarding@resend.dev"

# Habilita GET /api/email/test (solo funciona si NODE_ENV != production)
ENABLE_EMAIL_TEST="true"
